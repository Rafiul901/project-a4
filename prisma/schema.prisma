generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model profiles {
  id           String   @id
  bio          String?
  profilePhoto String?
  userId       String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  users        users    @relation(fields: [userId], references: [id])
}

model users {
  id           String       @id
  name         String       @db.VarChar(255)
  email        String       @unique
  password     String
  activeStatus ActiveStatus @default(ACTIVE)
  role         Role         @default(USER)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime
  profiles     profiles?
}

enum ActiveStatus {
  ACTIVE
  BLOCKED
}

enum Role {
  USER
  ADMIN
}
