
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String

  role      Role
  status    UserStatus @default(ACTIVE)

  properties Property[]
  rentals    RentalRequest[]
  reviews    Review[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([status])
}